# =====================================================================
# .gitignore — ADR Propensity Prediction (HealthLake + Clean Rooms ML)
# Only Lambda source code, CFN templates, deployment scripts,
# and documentation are committed. All generated artifacts are excluded.
# =====================================================================

# Lambda build artifacts — generated by dist/package_lambdas.py
# (zip files are committed to the repo for zero-code deployment — see dist/)
lambda/*.zip

# Kiro IDE configuration
.kiro/

# Internal working documents
*.docx
*.pdf
*.html
KIRO_*.md

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# AWS credentials (never commit)
.aws/

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Internal development and operational scripts — all .py files in dist/ are excluded.
# Only the pre-built Lambda zip artifacts in dist/ are published.
dist/*.py

# Patch/temp scripts written by Kiro during development
lambda/_patch_*.py

# Publication zip — lives in repo root but must not be committed or re-zipped
ADR-HealthLake-repo.zip

# Local review files — temporary, not for publication
architecture-preview.html
architecture-preview.mmd
architecture-preview-mermaid.png

# Internal override justifications — not for public repo
OVERRIDE_JUSTIFICATIONS.md
LINK_AUDIT.md
